{
  "name": "crawlready-monorepo",
  "version": "1.7.6",
  "private": true,
  "packageManager": "pnpm@9.6.0+sha512.38dc6fba8dba35b39340b9700112c2fe1e12f10b17134715a4aa98ccf7bb035e76fd981cf0bb384dfa98f8d6af5481c2bef2f4266a24bfa20c34eb7147ce0b5e",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm run dev --filter @crawlready/web...",
    "build": "turbo run build",
    "build:web": "pnpm run build --filter @crawlready/web...",
    "start": "t --filter @crawlready/web start",
    "clean": "turbo run clean && rimraf .turbo node_modules/.cache",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "check-types": "turbo run type-check",
    "test": "turbo run test",
    "test:web": "pnpm --filter @crawlready/web test",
    "test:packages": "pnpm --filter './packages/*' test",
    "test:e2e": "pnpm --filter @crawlready/web test:e2e",
    "commit": "cz",
    "db:generate": "pnpm --filter @crawlready/web db:generate",
    "db:migrate": "pnpm --filter @crawlready/web db:migrate",
    "db:push": "pnpm --filter @crawlready/web db:push",
    "db:studio": "pnpm --filter @crawlready/web db:studio",
    "storybook": "pnpm --filter @crawlready/web storybook",
    "storybook:build": "pnpm --filter @crawlready/web storybook:build",
    "prepare": "node -e \"if (process.env.CI !== 'true' && process.env.VERCEL !== '1') { try { require('husky').install() } catch (e) {} }\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/cz-commitlint": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "commitizen": "^4.3.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.5.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.9",
    "turbo": "^2.7.2",
    "typescript": "^5.6.3"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "overrides": {
      "ajv@6.12.6": "6.15.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "bn.js@<4.12.3": ">=4.12.3",
      "bn.js@>=5.0.0 <5.2.3": "5.2.3",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "checkly>glob": ">=11.1.0",
      "cosmiconfig>yaml": ">=2.8.3",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "esbuild@<=0.24.2": ">=0.25.0",
      "fdir>picomatch": ">=4.0.4",
      "flatted@<=3.4.1": ">=3.4.2",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "glob@11.0.3": "11.1.0",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
      "js-yaml@>=3.0.0 <3.14.2": "3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "micromatch>picomatch": ">=4.0.4",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "minimatch@>=3.0.0 <3.1.4": ">=3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=8.0.0 <8.0.6": "8.0.6",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "picomatch@4.0.3": "4.0.4",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "postcss-load-config>yaml": ">=2.8.3",
      "postcss@<8.5.10": ">=8.5.10",
      "preact@>=10.27.0 <10.27.3": ">=10.27.3",
      "qs@<6.14.2": ">=6.14.2",
      "rollup@>=3.0.0 <3.30.0": ">=3.30.0",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "sucrase>glob": ">=11.1.0",
      "svgo@=4.0.0": ">=4.0.1",
      "test-exclude>glob": ">=11.1.0",
      "tinyglobby>picomatch": ">=4.0.4",
      "tmp@<=0.2.3": ">=0.2.4",
      "uuid@<14.0.0": ">=14.0.0",
      "vite@<=6.4.1": ">=6.4.2",
      "webpack@>=5.49.0 <5.104.1": ">=5.104.1",
      "yaml@2.8.1": "2.8.3",
      "yaml@<1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
